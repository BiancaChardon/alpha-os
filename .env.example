# EIA API key: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# FRED API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Perplexity API key: https://www.perplexity.ai/settings/api
# Powers Search API, Agent API, and Embeddings API (single key for all)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Anthropic API key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Classification (text signals)
ANTHROPIC_CLASSIFICATION_MODEL=claude-3-5-haiku-latest

# Synthesis + Contrarian
ANTHROPIC_SYNTHESIS_MODEL=claude-sonnet-4-6

# Database
DATABASE_PATH=data/alpha_os.db

# Pipeline settings
SIGNAL_LOOKBACK_HOURS=24
INGESTION_FIXTURE_MODE=false
